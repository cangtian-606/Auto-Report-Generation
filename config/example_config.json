{
  "_comment": "Word模板转换器配置文件示例",
  
  "global_replacements": [
    ["公司名称", "{{ g.company_name }}"],
    ["报告编号", "{{ g.report_no }}"],
    ["日期", "{{ g.date }}"],
    ["签署人", "{{ g.signer }}"]
  ],
  
  "placeholder_pattern": "(?<![a-zA-Z_])[×X]{4,}(?![a-zA-Z_}])",
  "placeholder_template": "{{ notes.placeholder_{desc} }}",
  "note_pattern": "【注[：:].*?】?",
  
  "infer_descriptions": true,
  "context_length": 60
}
