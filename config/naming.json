{
    "template_naming": {
        "prefix": "tpl_",
        "suffix": ".docx",
        "description": "Template files must follow naming convention: tpl_<name>.docx"
    },
    "output_naming": {
        "suffix": "_output.docx",
        "description": "Output files are named: <original>_output.docx"
    },
    "data_naming": {
        "prefix": "data_",
        "description": "Data files should follow: data_<name>.xlsx"
    }
}